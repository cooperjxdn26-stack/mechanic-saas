generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/**
 * |--------------------------------------------------------------------------
 * | ENUMS PRINCIPALES
 * |--------------------------------------------------------------------------
 */

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CustomerType {
  NATURAL
  COMPANY
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  VIP
  DEBTOR
}

enum VehicleFuelType {
  GASOLINE
  DIESEL
  GAS
  HYBRID
  ELECTRIC
  OTHER
}

enum VehicleTransmission {
  MANUAL
  AUTOMATIC
  CVT
  OTHER
}

enum VehicleType {
  SEDAN
  SUV
  PICKUP
  VAN
  TRUCK
  MOTORCYCLE
  OTHER
}

enum WorkOrderStatus {
  PENDING
  RECEIVED
  IN_DIAGNOSIS
  WAITING_APPROVAL
  IN_REPAIR
  IN_TESTING
  COMPLETED
  DELIVERED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DiagnosticType {
  INITIAL
  TECHNICAL
  FINAL
  AI_SUGGESTED
}

enum ChecklistStatus {
  PENDING
  PASSED
  FAILED
  WARNING
}

enum ServiceCategory {
  ENGINE
  BRAKES
  SUSPENSION
  ELECTRICAL
  TIRES
  MAINTENANCE
  DIAGNOSTIC
  TRANSMISSION
  OTHER
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  LOSS
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum QuoteItemType {
  SERVICE
  PART
  LABOR
  EXTRA
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  YAPE
  PLIN
  POS
  CREDIT
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  INTERNAL
  EMAIL
  WHATSAPP
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum AttachmentType {
  IMAGE
  PDF
  DOCUMENT
  SIGNATURE
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  PAYMENT
  STATUS_CHANGE

  CREATE_BACKUP
  CREATE_BACKUP_FAILED
  DOWNLOAD_BACKUP
  RESTORE_BACKUP
}

enum MaintenanceReminderStatus {
  PENDING
  SENT
  COMPLETED
  CANCELLED
}

/**
 * |--------------------------------------------------------------------------
 * | MULTITENANCY / EMPRESA / SUCURSAL
 * |--------------------------------------------------------------------------
 */

model Company {
  id       String  @id @default(cuid())
  name     String
  ruc      String? @unique
  email    String?
  phone    String?
  address  String?
  logoUrl  String?
  isActive Boolean @default(true)

  branches             Branch[]
  users                User[]
  customers            Customer[]
  suppliers            Supplier[]
  services             Service[]
  parts                Part[]
  auditLogs            AuditLog[]
  complaintBookEntries ComplaintBookEntry[]
  backups              Backup[]             @relation("CompanyBackups")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Branch {
  id       String  @id @default(cuid())
  name     String
  address  String?
  phone    String?
  email    String?
  isMain   Boolean @default(false)
  isActive Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  users                User[]
  customers            Customer[]
  vehicles             Vehicle[]
  workOrders           WorkOrder[]
  appointments         Appointment[]
  cashRegisters        CashRegister[]
  purchases            Purchase[]
  inventoryMovements   InventoryMovement[]
  complaintBookEntries ComplaintBookEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([name])
}

/**
 * |--------------------------------------------------------------------------
 * | ROLES, PERMISOS Y USUARIOS
 * |--------------------------------------------------------------------------
 */

model User {
  id        String     @id @default(cuid())
  firstName String
  lastName  String
  email     String     @unique
  password  String
  phone     String?
  avatarUrl String?
  status    UserStatus @default(ACTIVE)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  assignedOrders WorkOrder[] @relation("MechanicOrders")
  createdOrders  WorkOrder[] @relation("CreatedOrders")

  diagnostics   Diagnostic[]
  comments      Comment[]
  notifications Notification[]
  auditLogs     AuditLog[]
  payments      Payment[]
  cashRegisters CashRegister[]
  backups       Backup[]       @relation("UserBackups")

  complaintsCreated     ComplaintBookEntry[]         @relation("ComplaintCreatedBy")
  complaintsResponsible ComplaintBookEntry[]         @relation("ComplaintResponsible")
  complaintsAnswered    ComplaintBookEntry[]         @relation("ComplaintAnsweredBy")
  complaintHistories    ComplaintBookStatusHistory[]
  complaintAttachments  ComplaintBookAttachment[]

  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  workOrderStatusHistories WorkOrderStatusHistory[]
  inventoryMovements       InventoryMovement[]
  attachments              Attachment[]

  @@index([companyId])
  @@index([branchId])
  @@index([roleId])
  @@index([email])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  module      String
  action      String
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
  @@index([action])
}

model RolePermission {
  id String @id @default(cuid())

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/**
 * |--------------------------------------------------------------------------
 * | CLIENTES Y VEHÍCULOS
 * |--------------------------------------------------------------------------
 */

model Customer {
  id     String         @id @default(cuid())
  type   CustomerType   @default(NATURAL)
  status CustomerStatus @default(ACTIVE)

  name           String
  documentNumber String?
  phone          String?
  email          String?
  address        String?
  notes          String?

  tags       String[] @default([])
  trustLevel Int      @default(0)
  visitCount Int      @default(0)
  totalDebt  Decimal  @default(0) @db.Decimal(12, 2)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  vehicles             Vehicle[]
  quotes               Quote[]
  invoices             Invoice[]
  payments             Payment[]
  appointments         Appointment[]
  maintenanceReminders MaintenanceReminder[]
  complaintBookEntries ComplaintBookEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([name])
  @@index([documentNumber])
  @@index([phone])
  @@index([email])
}

model Vehicle {
  id           String               @id @default(cuid())
  plate        String
  brand        String
  model        String
  year         Int?
  color        String?
  vin          String?
  mileage      Int                  @default(0)
  fuelType     VehicleFuelType?
  transmission VehicleTransmission?
  type         VehicleType?
  notes        String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  workOrders           WorkOrder[]
  quotes               Quote[]
  appointments         Appointment[]
  maintenanceReminders MaintenanceReminder[]
  complaintBookEntries ComplaintBookEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plate])
  @@index([customerId])
  @@index([branchId])
  @@index([vin])
  @@index([brand, model])
}

/**
 * |--------------------------------------------------------------------------
 * | ÓRDENES DE TRABAJO, DIAGNÓSTICOS Y CHECKLIST
 * |--------------------------------------------------------------------------
 */

model WorkOrder {
  id   String @id @default(cuid())
  code String @unique

  reason           String
  reportedSymptoms String?
  initialDiagnosis String?
  finalDiagnosis   String?
  internalNotes    String?

  status   WorkOrderStatus   @default(PENDING)
  priority WorkOrderPriority @default(MEDIUM)

  receivedAt        DateTime  @default(now())
  estimatedDelivery DateTime?
  deliveredAt       DateTime?

  qrToken              String? @unique
  customerSignatureUrl String?

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  mechanicId String?
  mechanic   User?   @relation("MechanicOrders", fields: [mechanicId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("CreatedOrders", fields: [createdById], references: [id], onDelete: SetNull)

  diagnostics          Diagnostic[]
  checklists           InspectionChecklist[]
  statusHistory        WorkOrderStatusHistory[]
  attachments          Attachment[]
  comments             Comment[]
  quotes               Quote[]
  invoices             Invoice[]
  complaintBookEntries ComplaintBookEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([branchId])
  @@index([mechanicId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([receivedAt])
}

model WorkOrderStatusHistory {
  id        String           @id @default(cuid())
  oldStatus WorkOrderStatus?
  newStatus WorkOrderStatus
  notes     String?

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([changedById])
  @@index([newStatus])
}

model Diagnostic {
  id           String         @id @default(cuid())
  type         DiagnosticType @default(TECHNICAL)
  title        String
  description  String
  aiSuggestion String?
  confidence   Int?
  solution     String?
  notes        String?

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  mechanicId String?
  mechanic   User?   @relation(fields: [mechanicId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workOrderId])
  @@index([mechanicId])
  @@index([type])
}

model InspectionChecklist {
  id     String          @id @default(cuid())
  item   String
  status ChecklistStatus @default(PENDING)
  notes  String?

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workOrderId])
}

/**
 * |--------------------------------------------------------------------------
 * | SERVICIOS, REPUESTOS, INVENTARIO Y COMPRAS
 * |--------------------------------------------------------------------------
 */

model Service {
  id                   String          @id @default(cuid())
  name                 String
  description          String?
  category             ServiceCategory @default(OTHER)
  basePrice            Decimal         @default(0) @db.Decimal(12, 2)
  estimatedTimeMinutes Int?
  isActive             Boolean         @default(true)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  quoteItems QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([name])
  @@index([category])
}

model Part {
  id          String  @id @default(cuid())
  name        String
  code        String?
  sku         String? @unique
  category    String?
  brand       String?
  description String?

  stock         Int     @default(0)
  minStock      Int     @default(0)
  purchasePrice Decimal @default(0) @db.Decimal(12, 2)
  salePrice     Decimal @default(0) @db.Decimal(12, 2)
  location      String?
  isActive      Boolean @default(true)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  movements     InventoryMovement[]
  purchaseItems PurchaseItem[]
  quoteItems    QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([supplierId])
  @@index([name])
  @@index([code])
  @@index([category])
  @@index([stock])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  type          InventoryMovementType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  reference     String?

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([partId])
  @@index([branchId])
  @@index([createdById])
  @@index([type])
  @@index([createdAt])
}

model Supplier {
  id          String  @id @default(cuid())
  name        String
  ruc         String?
  phone       String?
  email       String?
  address     String?
  contactName String?
  notes       String?
  isActive    Boolean @default(true)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  parts     Part[]
  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([name])
  @@index([ruc])
}

model Purchase {
  id       String         @id @default(cuid())
  code     String         @unique
  status   PurchaseStatus @default(DRAFT)
  subtotal Decimal        @default(0) @db.Decimal(12, 2)
  tax      Decimal        @default(0) @db.Decimal(12, 2)
  total    Decimal        @default(0) @db.Decimal(12, 2)
  notes    String?

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@index([partId])
}

/**
 * |--------------------------------------------------------------------------
 * | COTIZACIONES, FACTURACIÓN, PAGOS Y CAJA
 * |--------------------------------------------------------------------------
 */

model Quote {
  id     String      @id @default(cuid())
  code   String      @unique
  status QuoteStatus @default(DRAFT)

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  tax      Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  validUntil  DateTime?
  publicToken String?   @unique
  approvedAt  DateTime?
  rejectedAt  DateTime?
  notes       String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  items   QuoteItem[]
  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@index([workOrderId])
  @@index([status])
  @@index([createdAt])
}

model QuoteItem {
  id          String        @id @default(cuid())
  type        QuoteItemType
  description String
  quantity    Int           @default(1)
  unitPrice   Decimal       @default(0) @db.Decimal(12, 2)
  discount    Decimal       @default(0) @db.Decimal(12, 2)
  total       Decimal       @default(0) @db.Decimal(12, 2)

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  partId String?
  part   Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([quoteId])
  @@index([serviceId])
  @@index([partId])
  @@index([type])
}

model Invoice {
  id     String        @id @default(cuid())
  code   String        @unique
  status InvoiceStatus @default(DRAFT)

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  tax      Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  issuedAt DateTime?
  pdfUrl   String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  quoteId String? @unique
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([workOrderId])
  @@index([status])
  @@index([issuedAt])
}

model Payment {
  id        String        @id @default(cuid())
  code      String        @unique
  method    PaymentMethod
  status    PaymentStatus @default(PAID)
  amount    Decimal       @default(0) @db.Decimal(12, 2)
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)

  receivedById String?
  receivedBy   User?   @relation(fields: [receivedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([invoiceId])
  @@index([cashRegisterId])
  @@index([receivedById])
  @@index([method])
  @@index([paidAt])
}

model CashRegister {
  id     String             @id @default(cuid())
  code   String             @unique
  status CashRegisterStatus @default(OPEN)

  openingAmount  Decimal  @default(0) @db.Decimal(12, 2)
  closingAmount  Decimal? @db.Decimal(12, 2)
  expectedAmount Decimal? @db.Decimal(12, 2)
  difference     Decimal? @db.Decimal(12, 2)

  openedAt DateTime  @default(now())
  closedAt DateTime?
  notes    String?

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  openedById String?
  openedBy   User?   @relation(fields: [openedById], references: [id], onDelete: SetNull)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([openedById])
  @@index([status])
  @@index([openedAt])
}

/**
 * |--------------------------------------------------------------------------
 * | AGENDA, NOTIFICACIONES, ARCHIVOS, COMENTARIOS Y RECORDATORIOS
 * |--------------------------------------------------------------------------
 */

model Appointment {
  id          String            @id @default(cuid())
  title       String
  description String?
  status      AppointmentStatus @default(SCHEDULED)
  startAt     DateTime
  endAt       DateTime
  reminderAt  DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@index([branchId])
  @@index([status])
  @@index([startAt])
}

model Notification {
  id        String             @id @default(cuid())
  title     String
  message   String
  type      NotificationType   @default(INTERNAL)
  status    NotificationStatus @default(PENDING)
  actionUrl String?
  sentAt    DateTime?
  readAt    DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model Attachment {
  id       String         @id @default(cuid())
  filename String
  url      String
  mimeType String?
  size     Int?
  type     AttachmentType @default(OTHER)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([uploadedById])
  @@index([type])
}

model Comment {
  id         String  @id @default(cuid())
  content    String
  isInternal Boolean @default(true)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workOrderId])
  @@index([userId])
}

model MaintenanceReminder {
  id          String                    @id @default(cuid())
  title       String
  description String?
  dueMileage  Int?
  dueDate     DateTime?
  status      MaintenanceReminderStatus @default(PENDING)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([dueDate])
}

/**
 * |--------------------------------------------------------------------------
 * | AUDITORÍA
 * |--------------------------------------------------------------------------
 */

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  module      String
  entity      String?
  entityId    String?
  description String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entityId])
  @@index([createdAt])
}

/**
 * |--------------------------------------------------------------------------
 * | LIBRO DE RECLAMACIONES
 * |--------------------------------------------------------------------------
 */

enum ComplaintDocumentType {
  DNI
  CE
  RUC
  PASSPORT
  OTHER
}

enum ComplaintGoodType {
  PRODUCT
  SERVICE
  PART
  OTHER
}

enum ComplaintCaseType {
  CLAIM
  COMPLAINT
}

enum ComplaintResponseMethod {
  EMAIL
  PHONE
  WHATSAPP
  IN_PERSON
}

enum ComplaintBookStatus {
  REGISTERED
  UNDER_REVIEW
  ANSWERED
  CLOSED
  EXPIRED
  CANCELLED
}

enum ComplaintAttachmentCategory {
  CUSTOMER_EVIDENCE
  PROVIDER_RESPONSE
  INTERNAL
}

/**
 * |--------------------------------------------------------------------------
 * | LIBRO DE RECLAMACIONES
 * |--------------------------------------------------------------------------
 */

model ComplaintBookEntry {
  id   String @id @default(cuid())
  code String @unique

  /**
   * Datos generales del libro
   */
  physicalSheetNumber String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  /**
   * Relaciones opcionales con el sistema
   */
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  /**
   * 1. Identificación del consumidor reclamante
   */
  claimantType           CustomerType          @default(NATURAL)
  claimantName           String
  claimantDocumentType   ComplaintDocumentType @default(DNI)
  claimantDocumentNumber String
  claimantAddress        String?
  claimantPhone          String?
  claimantEmail          String?

  /**
   * Datos del padre, madre o apoderado
   */
  isMinor                Boolean                @default(false)
  guardianName           String?
  guardianDocumentType   ComplaintDocumentType?
  guardianDocumentNumber String?
  guardianAddress        String?
  guardianPhone          String?
  guardianEmail          String?

  /**
   * 2. Identificación del bien contratado
   */
  goodType        ComplaintGoodType
  claimedAmount   Decimal?          @db.Decimal(12, 2)
  goodDescription String

  /**
   * Datos adaptados al taller mecánico
   */
  serviceOrderCode String?
  vehiclePlate     String?
  vehicleBrand     String?
  vehicleModel     String?
  serviceDate      DateTime?
  paymentDocument  String?

  /**
   * 3. Detalle de la reclamación
   */
  caseType        ComplaintCaseType
  detail          String
  customerRequest String
  responseMethod  ComplaintResponseMethod?

  /**
   * 4. Observaciones y acciones adoptadas por el proveedor
   */
  providerObservation String?
  actionsTaken        String?
  responseDetail      String?

  /**
   * Control interno
   */
  status ComplaintBookStatus @default(REGISTERED)

  createdById String?
  createdBy   User?   @relation("ComplaintCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  responsibleId String?
  responsible   User?   @relation("ComplaintResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  answeredById String?
  answeredBy   User?   @relation("ComplaintAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)

  registeredAt DateTime  @default(now())
  dueDate      DateTime?
  answeredAt   DateTime?
  closedAt     DateTime?

  acceptedDeclaration Boolean @default(false)

  attachments ComplaintBookAttachment[]
  histories   ComplaintBookStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([workOrderId])
  @@index([createdById])
  @@index([responsibleId])
  @@index([answeredById])
  @@index([code])
  @@index([status])
  @@index([caseType])
  @@index([claimantDocumentNumber])
  @@index([vehiclePlate])
  @@index([registeredAt])
  @@index([dueDate])
}

model ComplaintBookAttachment {
  id String @id @default(cuid())

  complaintBookEntryId String
  complaintBookEntry   ComplaintBookEntry @relation(fields: [complaintBookEntryId], references: [id], onDelete: Cascade)

  filename String
  url      String
  mimeType String?
  size     Int?

  type     AttachmentType              @default(OTHER)
  category ComplaintAttachmentCategory @default(CUSTOMER_EVIDENCE)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([complaintBookEntryId])
  @@index([uploadedById])
  @@index([type])
  @@index([category])
}

model ComplaintBookStatusHistory {
  id String @id @default(cuid())

  complaintBookEntryId String
  complaintBookEntry   ComplaintBookEntry @relation(fields: [complaintBookEntryId], references: [id], onDelete: Cascade)

  oldStatus ComplaintBookStatus?
  newStatus ComplaintBookStatus

  comment String?

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([complaintBookEntryId])
  @@index([changedById])
  @@index([newStatus])
  @@index([createdAt])
}

/**
 * |--------------------------------------------------------------------------
 * | GESTIÓN DE CONTINUIDAD DEL SERVICIO
 * |--------------------------------------------------------------------------
 */

enum BackupType {
  MANUAL
  AUTOMATIC
}

enum BackupStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RESTORED
}

model Backup {
  id String @id @default(cuid())

  filename String
  path     String?

  type BackupType @default(MANUAL)

  status BackupStatus @default(PENDING)

  size String?

  companyId String?
  company   Company? @relation("CompanyBackups", fields: [companyId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("UserBackups", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}
